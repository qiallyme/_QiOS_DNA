{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QiOne Tag Classes Schema",
  "type": "object",
  "required": [
    "class",
    "description",
    "scope"
  ],
  "properties": {
    "class": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "description": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "max_per_doc": {
      "type": [
        "string",
        "null"
      ]
    },
    "required": {
      "type": [
        "string",
        "null"
      ]
    },
    "examples": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}